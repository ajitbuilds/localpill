{
  "database": {
    "rules": "database.rules.json"
  },
  "firestore": {
    "rules": "firestore.rules",
    "indexes": "firestore.indexes.json"
  },
  "storage": {
    "rules": "storage.rules"
  },
  "hosting": [
    {
      "site": "localpill",
      "public": "dist",
      "ignore": [
        "firebase.json",
        "**/.*",
        "**/node_modules/**"
      ],
      "rewrites": [
        {
          "source": "/sitemap.xml",
          "function": "generateSitemap"
        },
        {
          "source": "/robots.txt",
          "destination": "/robots.txt"
        },
        {
          "source": "/privacy-policy",
          "destination": "/privacy-policy.html"
        },
        {
          "source": "/s/**",
          "destination": "/share.html"
        },
        {
          "source": "**",
          "destination": "/index.html"
        }
      ]
    },
    {
      "site": "localpill-upcharmitra",
      "public": "dist",
      "ignore": [
        "firebase.json",
        "**/.*",
        "**/node_modules/**"
      ],
      "rewrites": [
        {
          "source": "/sitemap.xml",
          "function": "generateSitemap"
        },
        {
          "source": "/robots.txt",
          "destination": "/robots.txt"
        },
        {
          "source": "/s/**",
          "destination": "/share.html"
        },
        {
          "source": "**",
          "destination": "/index.html"
        }
      ]
    }
  ],
  "functions": [
    {
      "codebase": "default",
      "disallowLegacyRuntimeConfig": true,
      "ignore": [
        "node_modules",
        ".git",
        "firebase-debug.log",
        "firebase-debug.*.log",
        "*.local"
      ],
      "predeploy": [],
      "source": "functions"
    }
  ]
}
