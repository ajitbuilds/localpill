        "googleMapsApiKey": "AIzaSyAiLT7VoR8wnG5-EYTgk5OT9YqIVAV9-Wk"
      }
    },
    "android": {
      "package": "com.localpill.pharmacyapp",
      "versionCode": 1,
      "googleServicesFile": "./google-services.json",
