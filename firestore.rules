rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    
    // --- Global Helper Functions ---
    function isAuthenticated() {
      return request.auth != null;
    }
    
    function isOwner(userId) {
      return isAuthenticated() && request.auth.uid == userId;
    }
    
    function getUserRole() {
      // Safely fetches the role of the currently authenticated user
      return get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role;
    }
    
    function isPharmacy() {
      return isAuthenticated() && getUserRole() == 'pharmacy';
    }

    function isAdmin() {
      return isAuthenticated() && getUserRole() == 'admin';
    }

    // Safely checks if a user is suspended (returns false if doc/field missing)
    function isUserSuspended(uid) {
      let userDoc = get(/databases/$(database)/documents/users/$(uid));
      return userDoc != null && userDoc.data.get('isSuspended', false) == true;
    }

    // Safely checks if a pharmacy is suspended
    function isPharmacySuspended(uid) {
      let pharmDoc = get(/databases/$(database)/documents/pharmacies/$(uid));
      return pharmDoc != null && pharmDoc.data.get('isSuspended', false) == true;
    }

    // --- Users & Profiles ---

    // Public Testimonials (Issue #35)
    match /testimonials/{docId} {
      allow read: if true;
      allow write: if false;
    }
    
    match /users/{userId} {
      // SEC FIX: Restricted from any-auth to owner/admin only (was leaking PII)
      allow read: if isOwner(userId) || isAdmin();
      // New user creating their profile for the first time
      allow create: if isOwner(userId);
      // Users can update their own profile, with restrictions:
      // - 'isSuspended' can never be self-changed (admin only)
      // - 'role' can be set ONLY if the existing role is empty (first-time setup). Once a role is assigned, only admins can change it.
      allow update: if isAdmin()
        || (isOwner(userId)
            && !request.resource.data.diff(resource.data).affectedKeys().hasAny(['isSuspended'])
            && (
                !request.resource.data.diff(resource.data).affectedKeys().hasAny(['role'])
                || resource.data.role == ''
                || resource.data.role == null
            )
        );
      // Allow user to delete their own document (for account deletion flow)
      allow delete: if isOwner(userId);
    }

    match /patients/{patientId} {
      allow read, write: if isOwner(patientId);
    }

    match /pharmacies/{pharmacyId} {
      // Allow public read for online pharmacy count on the home screen and directory
      allow read: if true;
      // New pharmacy creating their profile for the first time
      allow create: if isOwner(pharmacyId);
      // Pharmacy can update its own profile EXCEPT verification or suspension status (admin only)
      allow update: if isAdmin() || (isOwner(pharmacyId) && (!request.resource.data.diff(resource.data).affectedKeys().hasAny(['isVerified', 'isSuspended'])));
      allow delete: if false;
    }

    // --- Platform Settings (admin writes, authenticated reads) ---
    match /settings/{docId} {
      allow read: if isAuthenticated();
      allow write: if isAdmin();
    }

    // --- Admin Stats ---
    match /admin_stats/{docId} {
      allow read, write: if isAdmin();
    }

    // --- Core Matching Engine: medicineRequests ---
    
    match /medicineRequests/{requestId} {
      
      // SEC FIX: Issue #10 - Only pharmacies searching local requests should see pending requests
      function isPendingRequest() {
        return resource.data.status == 'pending' && (isPharmacy() || isAdmin());
      }

      function isAssignedPharmacy() {
        return request.auth != null
          && resource.data.assignedTo == request.auth.uid;
      }

      // PATIENT read
      function isPatient() {
        return request.auth != null
          && resource.data.userId == request.auth.uid;
      }

      // FINAL READ RULE
      allow read: if isAdmin()
                   || (request.auth != null && resource.data.userId == request.auth.uid)
                   || (request.auth != null && resource.data.targetPharmacyIds != null && request.auth.uid in resource.data.targetPharmacyIds)
                   || (request.auth != null && resource.data.respondedPharmacies != null && request.auth.uid in resource.data.respondedPharmacies)
                   || isAssignedPharmacy()
                   || isPendingRequest();

      allow create: if request.auth != null && !isUserSuspended(request.auth.uid);

      function isPharmacyUpdatingResponse() {
        return request.auth != null 
          && isPharmacy()
          && request.resource.data.diff(resource.data).affectedKeys().hasOnly(['respondedPharmacies'])
          && request.auth.uid in request.resource.data.respondedPharmacies;
      }

      // Allow the patient to update their request (e.g. to cancel it)
      // Or a pharmacy to mark that they've responded
      allow update: if isPatient() || isPharmacyUpdatingResponse();
      allow delete: if false;

      // --- Nested Subcollection: pharmacyResponses ---
      match /pharmacyResponses/{pharmacyId} {
        
        // Read: The Patient who submitted the parent request OR the responding Pharmacy
        allow read: if (request.auth != null && get(/databases/$(database)/documents/medicineRequests/$(requestId)).data.userId == request.auth.uid)
                    || isOwner(pharmacyId)
                    || isAdmin();
        
        // Create: Only the designated Pharmacy can write, un-suspended
        allow create: if isOwner(pharmacyId) && isPharmacy() && !isPharmacySuspended(request.auth.uid);
        
        // Update & Delete: Locked.
        allow update, delete: if false;
      }
      

    }

    // --- Mobile App Collection: medicine_requests (snake_case used by customer app) ---
    match /medicine_requests/{requestId} {

      // Patient who owns the request
      function isMobilePatient() {
        return request.auth != null
          && resource.data.userId == request.auth.uid;
      }

      // Allow get (single doc read) for owner, assigned pharmacy, or admin
      allow get: if isAdmin()
                   || (request.auth != null && resource.data.userId == request.auth.uid)
                   || (request.auth != null && resource.data.targetPharmacyIds != null && request.auth.uid in resource.data.targetPharmacyIds)
                   || (request.auth != null && resource.data.respondedPharmacies != null && request.auth.uid in resource.data.respondedPharmacies)
                   || (request.auth != null && resource.data.assignedTo == request.auth.uid);

      // SEC FIX: List restricted to patient's own requests only (was open to any auth user)
      allow list: if request.auth != null
                   && request.query.limit <= 100
                   && resource.data.userId == request.auth.uid;

      // Any authenticated user can create a request
      allow create: if request.auth != null;

      // Only the patient who owns it or admin can update (e.g. cancel)
      allow update: if isMobilePatient() || isAdmin();
      allow delete: if false;

      // SEC FIX: Responses subcollection locked to owner + targeted pharmacy (was open to any auth user)
      match /responses/{responseId} {
        allow read: if isAdmin()
                     || (request.auth != null && get(/databases/$(database)/documents/medicine_requests/$(requestId)).data.userId == request.auth.uid)
                     || isOwner(responseId);
        allow create: if request.auth != null && isPharmacy() && !isPharmacySuspended(request.auth.uid);
        allow update, delete: if false;
      }
    }

    // --- Developer & Backend Diagnostics (FULL LOCKDOWN) ---
    // Only Firebase Admin SDK running in secure Cloud Functions can read/write here.
    
    match /matchingLogs/{logId} {
      // SEC FIX: Issue #5 - Exists in production, limit to admin only
      allow read, write: if isAdmin();
    }

    match /functionErrors/{errorId} {
      allow read, write: if false; 
    }

    // --- Notifications (top-level) ---
    match /notifications/{userId}/{document=**} {
      allow read, write: if isOwner(userId) || isAdmin();
    }

    // --- Notifications (under users/{uid}/notifications) used by mobile app ---
    match /users/{userId}/notifications/{notifId} {
      allow read, write: if isOwner(userId) || isAdmin();
    }

    // collectionGroup read for RequestHistory & fast responder badge (pharmacies reading their own responses)
    match /{path=**}/pharmacyResponses/{docId} {
      allow read: if request.auth != null && (
        isAdmin() || resource.data.pharmacyId == request.auth.uid || request.auth.uid == docId
      );
    }

    // --- Location Requests (Ask them to share location) ---
    match /locationRequests/{reqId} {
      // Authenticated users (Customer App) can create their own requests
      allow create: if isAuthenticated();
      // SEC FIX: Allow single document read only within 30-minute window (was open with no expiry)
      allow get: if resource.data.status == 'pending'
                  && resource.data.createdAt > request.time - duration.value(30, 'm');
      // If completed or for the creator, allow read by authenticated user
      allow get: if isAuthenticated() && resource.data.createdBy == request.auth.uid;
      // Listing is still restricted to authenticated users (owner or when completed)
      allow list: if isAuthenticated() && (resource.data.createdBy == request.auth.uid || resource.data.status == 'completed');
      // The web app (unauthenticated patient) can update the document to add location
      allow update: if request.resource.data.diff(resource.data).affectedKeys().hasOnly(['status', 'lat', 'lng', 'address', 'accuracy'])
                    && request.resource.data.status == 'completed';
      allow delete: if false;
    }
  }
}
